NODE_ENV=development
PORT=4000
DATABASE_URL=postgresql://postgres:your_postgres_password@localhost:5432/driveportal?schema=public
# Docker Compose backend URL example:
# DATABASE_URL=postgresql://postgres:postgres@db:5432/driveportal?schema=public
JWT_SECRET=replace-this-with-a-long-random-secret
# When true, /api/auth/register is enabled (new accounts are USER role only).
ALLOW_SELF_REGISTRATION=false
STORAGE_DRIVER=local
LOCAL_UPLOAD_DIR=uploads
S3_REGION=
S3_BUCKET=
